# Server
NODE_ENV=development
PORT=5000

# PostgreSQL (option A: single URL — use real values, no ${VAR} placeholders)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/otp_auth_db

# PostgreSQL (option B: separate fields — recommended)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=otp_auth_db
DB_USER=postgres
DB_PASSWORD=password

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

# MSG91 SMS API
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-msg91-otp-template-id
MSG91_SENDER_ID=OTPAUTH

# CORS
CLIENT_URL=http://localhost:5173

# Rate Limiting (OTP endpoints)
OTP_RATE_LIMIT_WINDOW_MS=900000
OTP_RATE_LIMIT_MAX=5

# Test user (npm run seed) — development only
TEST_USER_MOBILE=8128187135
TEST_USER_PASSWORD=Testing123
TEST_USER_NAME=Test User
